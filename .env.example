# Copy this file to .env and adjust values for local development.
# Never commit the real .env file — it is gitignored.
# These are local-only development defaults. They are not production secrets
# and must never be reused outside a developer's machine.

# ---------- PostgreSQL ----------
POSTGRES_DB=fulfillx_orders
POSTGRES_USER=fulfillx
POSTGRES_PASSWORD=fulfillx
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- Redpanda ----------
REDPANDA_KAFKA_PORT=9092
REDPANDA_PANDAPROXY_PORT=8082
REDPANDA_ADMIN_PORT=9644

# ---------- order-service (consumed directly by Spring, not docker-compose) ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fulfillx_orders
SPRING_DATASOURCE_USERNAME=fulfillx
SPRING_DATASOURCE_PASSWORD=fulfillx

# ---------- auth-service (consumed directly by Spring, not docker-compose) ----------
# Separate logical database from order-service; see
# docs/decisions/ADR-002-identity-and-cross-service-data-ownership.md.
# Shares the same Postgres superuser credentials as order-service for local
# dev only — production would use a distinct least-privilege role per
# service/database.
AUTH_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fulfillx_auth
AUTH_DATASOURCE_USERNAME=fulfillx
AUTH_DATASOURCE_PASSWORD=fulfillx

# Dev-only signing key, at least 32 bytes for HS256. Never reuse this value
# anywhere but a local machine; production must supply its own via real
# secret management, never a committed file.
AUTH_JWT_SECRET=dev-only-change-me-in-every-real-environment-please-32bytes-min
AUTH_JWT_EXPIRATION_MINUTES=30

# ---------- inventory-service (consumed directly by Spring, not docker-compose) ----------
# Separate logical database from order-service and auth-service; see
# docs/decisions/ADR-002-identity-and-cross-service-data-ownership.md.
# Shares the same Postgres superuser credentials for local dev only, same
# tradeoff as auth-service/order-service.
INVENTORY_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fulfillx_inventory
INVENTORY_DATASOURCE_USERNAME=fulfillx
INVENTORY_DATASOURCE_PASSWORD=fulfillx

# inventory-service validates auth-service-issued JWTs locally and therefore
# must share the same signing secret — never a different one.
